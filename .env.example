# ============================================================
# AUTOMATED RESUME SCREENING - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy to .env and fill in your API keys:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# GROQ API KEYS (comma-separated for rotation)
# Add multiple keys to avoid rate limits
# ------------------------------------------------------------
GROQ_API_KEYS=

# ------------------------------------------------------------
# LLM CONFIGURATION (ALL nodes use Groq now)
# ------------------------------------------------------------
# Node 1: Question Generation
QUESTION_GEN_URL=https://api.groq.com/openai/v1
QUESTION_GEN_MODEL=llama-3.3-70b-versatile

# Node 2: Resume Evaluation (RAG-based)
EVAL_URL=https://api.groq.com/openai/v1
EVAL_MODEL=llama-3.3-70b-versatile

# Node 4: Response/Summary Generation
RESPONSE_GEN_URL=https://api.groq.com/openai/v1
RESPONSE_GEN_MODEL=llama-3.3-70b-versatile

# ------------------------------------------------------------
# THRESHOLDS & SETTINGS
# ------------------------------------------------------------
CITATION_THRESHOLD=0.55
CITATION_REQUIRED_SCORE=3
FALLBACK_THRESHOLD=0.45
EMBEDDING_MODEL=all-MiniLM-L6-v2

# RAG Settings (Node 2)
RAG_CHUNK_SIZE=100
RAG_CHUNK_OVERLAP=20
RAG_TOP_K=3

# Validation Chunk Settings (Node 3)
VALIDATION_CHUNK_SIZE=30
VALIDATION_CHUNK_OVERLAP=10

# Timeouts (seconds)
LLM_TIMEOUT=60
CLOUD_LLM_TIMEOUT=60

# Max tokens for evaluation reasoning
MAX_REASONING_TOKENS=500



